{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Eyes",
  "version": "0.2.0",
  "identifier": "com.cislunarspace.eyes",
  "build": {
    "beforeDevCommand": "npm run dev -- --host 127.0.0.1",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Eyes",
        "width": 800,
        "height": 600,
        "resizable": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "icon": ["icons/icon.ico"],
    "resources": [
      "../models/face_detection_yunet_2023mar.onnx",
      "onnxruntime.dll"
    ],
    "windows": {
      "nsis": null
    }
  }
}
